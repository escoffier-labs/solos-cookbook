#!/usr/bin/env bash
# pre-push: block a push when Brigade guard finds policy violations.
# Drop this file in <repo>/hooks/pre-push, then activate once with:
#   git config core.hooksPath hooks
set -euo pipefail

if ! command -v brigade >/dev/null 2>&1; then
  echo "pre-push: brigade not found on PATH" >&2
  echo "pre-push: install with: pipx install brigade-cli" >&2
  exit 1
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

zero="0000000000000000000000000000000000000000"
failed=0
refs="$(cat)"

echo "pre-push: scanning tracked files with Brigade guard"
brigade guard git --all-tracked || failed=1

while read -r _local_ref local_sha _remote_ref remote_sha; do
  [[ -z "${local_sha:-}" || "$local_sha" == "$zero" ]] && continue
  if [[ "$remote_sha" == "$zero" ]]; then
    range="$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi
  echo "pre-push: scanning content introduced in $range"
  brigade guard git --history --range "$range" || failed=1
done <<<"$refs"

if [[ "$failed" -ne 0 ]]; then
  echo >&2
  echo "pre-push: BLOCKED. Fix the reported content before pushing." >&2
  echo "pre-push: A narrow allow comment may be used only for public example data:" >&2
  echo "pre-push:   <!-- content-guard: allow <rule-id> -->" >&2
  exit 1
fi
