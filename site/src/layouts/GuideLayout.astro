---
import BaseLayout from './BaseLayout.astro';
import RecipeMeta from '../components/RecipeMeta.astro';
import RecipeTOC from '../components/RecipeTOC.astro';
import { toRoman } from '../lib/cookbook.ts';
import { sitePath } from '../lib/site.ts';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface GuideRef {
  data: { title: string; category: string; slug: string };
}
interface Props {
  title: string;
  description: string;
  chapter: string;
  chapterNumber: number;
  category: string;
  testedOn?: string | undefined;
  lastUpdated?: string | undefined;
  headings: Heading[];
  prev?: GuideRef | undefined;
  next?: GuideRef | undefined;
}
const { title, description, chapter, chapterNumber, category, testedOn, lastUpdated, headings, prev, next } = Astro.props;
---
<BaseLayout
  title={`${title} - Solomon's Cookbook`}
  description={description}
  pageKind="article"
  dateModified={lastUpdated?.slice(0, 10)}
>
  <main class="px-6 md:px-10 py-10 flex gap-10 max-w-6xl mx-auto">
    <article class="prose-docs min-w-0 flex-1">
      <a href={sitePath(`/${category}/`)} class="chapter-kicker" style="text-decoration: none;">
        Chapter {toRoman(chapterNumber)} · {chapter}
      </a>
      <h1 class="font-display text-4xl mt-2 mb-4" style="color: var(--text);">{title}</h1>
      <RecipeMeta testedOn={testedOn} lastUpdated={lastUpdated} />
      <slot />
      {(prev || next) && (
        <nav class="recipe-pager">
          {prev ? (
            <a href={sitePath(`/${prev.data.category}/${prev.data.slug}/`)}>
              <span class="pager-label">← Previous</span>
              <div class="pager-title">{prev.data.title}</div>
            </a>
          ) : <span class="flex-1"></span>}
          {next ? (
            <a href={sitePath(`/${next.data.category}/${next.data.slug}/`)} class="text-right">
              <span class="pager-label">Next →</span>
              <div class="pager-title">{next.data.title}</div>
            </a>
          ) : <span class="flex-1"></span>}
        </nav>
      )}
    </article>
    <RecipeTOC headings={headings} />
  </main>
</BaseLayout>
