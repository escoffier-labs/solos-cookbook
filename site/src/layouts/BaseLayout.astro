---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { SITE, EXTERNAL, sitePath } from '../lib/site.ts';
import { buildPageMetadata, type PageKind } from '../lib/metadata.ts';

const {
  title = `${SITE.name} - production-tested recipes for AI agent stacks`,
  description = SITE.description,
  pageKind = 'website',
  dateModified,
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://escoffierlabs.dev');
const canonicalUrl = new URL(sitePath(Astro.url.pathname), siteUrl).toString();
const imageUrl = new URL(SITE.image, siteUrl).toString();
const keywords = [
  'AI agent cookbook',
  'OpenClaw recipes',
  'agent memory',
  'multi-agent stack',
  'Codex CLI',
  'Claude Code',
  'agent security hardening',
  'self-hosted AI agents',
  'bare metal AI stack',
  'AGENTS.md',
].join(', ');
const { openGraphType, structuredData } = buildPageMetadata({
  kind: pageKind as PageKind,
  title,
  description,
  url: canonicalUrl,
  image: imageUrl,
  license: EXTERNAL.contentLicense,
  dateModified,
});
---
<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Solomon Neas" />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={openGraphType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content="Solomon's Cookbook - recipes for AI agent stacks" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content="Solomon's Cookbook - recipes for AI agent stacks" />
    <link rel="icon" href={sitePath('/favicon.svg')} />
    <Analytics />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <script is:inline>
      (() => { try { const t = localStorage.getItem('cookbook-theme'); if (t) document.documentElement.dataset.theme = t; } catch {} })();
    </script>
  </head>
  <body>
    <SiteNav />
    <slot />
    <SiteFooter />
  </body>
</html>
