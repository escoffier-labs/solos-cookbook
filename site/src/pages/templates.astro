---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { EXTERNAL } from '../lib/site.ts';

const entry = await getEntry('appendix', 'templates');
if (!entry) throw new Error('templates appendix entry missing');
const { Content } = await render(entry);
---
<BaseLayout title="Templates - Solomon's Cookbook" description={entry.data.intro}>
  <main class="px-6 md:px-10 py-12 max-w-3xl mx-auto">
    <span class="kicker">Appendix</span>
    <h1 class="font-display text-4xl md:text-5xl mt-3 mb-8">{entry.data.title}</h1>
    <div class="prose-docs">
      <Content />
    </div>
    <p class="mt-10">
      <a href={`${EXTERNAL.repoTree}/templates`} class="px-5 py-2.5 rounded-lg border inline-block"
        style="border-color: var(--hairline); background: var(--bg-panel); text-decoration: none;">
        Browse templates on GitHub →
      </a>
    </p>
  </main>
</BaseLayout>
