---
// site/src/pages/book/index.astro
import { getCollection, render } from 'astro:content';
import BookCover from '../../components/BookCover.astro';
import StartHere from '../../components/StartHere.astro';
import Appendix from '../../components/Appendix.astro';
import { toRoman } from '../../lib/cookbook.ts';
import '../../styles/print.css';
import memoryOwnershipSvg from '../../diagrams/memory-ownership.svg?raw';
import multiHarnessHandoffSvg from '../../diagrams/multi-harness-handoff.svg?raw';
import stackTopologySvg from '../../diagrams/stack-topology.svg?raw';
import securityTiersSvg from '../../diagrams/security-tiers.svg?raw';
import automationFlowSvg from '../../diagrams/automation-flow.svg?raw';
import publishingPipelineSvg from '../../diagrams/publishing-pipeline.svg?raw';

const CHAPTER_DIAGRAMS: Record<string, string> = {
  'ai-stack': memoryOwnershipSvg,
  'automation': automationFlowSvg,
  'knowledge': multiHarnessHandoffSvg,
  'infrastructure': stackTopologySvg,
  'security': securityTiersSvg,
  'publishing': publishingPipelineSvg,
};

const chapters = await getCollection('chapters');
const guides = await getCollection('guides');

const orderedChapters = [...chapters].sort((a, b) => a.data.number - b.data.number);

function guidesForChapter(category: string) {
  return [...guides]
    .filter((g) => g.data.category === category)
    .sort((a, b) => a.data.chapterNumber - b.data.chapterNumber || a.data.slug.localeCompare(b.data.slug));
}

const rendered = [];
for (const chapter of orderedChapters) {
  const { Content: ChapterContent } = await render(chapter);
  const chapterGuides = [];
  for (const g of guidesForChapter(chapter.data.category)) {
    const { Content: GuideContent } = await render(g);
    chapterGuides.push({ entry: g, GuideContent });
  }
  rendered.push({ chapter, ChapterContent, guides: chapterGuides });
}
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Solomon's Guide to Cookin' with Gas</title>
  </head>
  <body>
    <BookCover />
    <nav class="toc">
      <h1>Contents</h1>
      {rendered.map(({ chapter, guides }) => (
        <div class="toc-chapter">
          <a href={`#ch-${chapter.data.category}`}>
            <span class="toc-label">
              <span class="toc-num">{toRoman(chapter.data.number)}</span>
              <span class="toc-text">{chapter.data.title}</span>
            </span>
          </a>
          {guides.map(({ entry }) => (
            <div class="toc-guide">
              <a href={`#g-${entry.data.category}-${entry.data.slug}`}>
                <span class="toc-text">{entry.data.title}</span>
              </a>
            </div>
          ))}
        </div>
      ))}
      <div class="toc-chapter">
        <a href="#appendix-templates">
          <span class="toc-label">
            <span class="toc-num">A</span>
            <span class="toc-text">Appendix</span>
          </span>
        </a>
        <div class="toc-guide">
          <a href="#appendix-templates">
            <span class="toc-text">Templates reference</span>
          </a>
        </div>
        <div class="toc-guide">
          <a href="#appendix-checklist">
            <span class="toc-text">Setup checklist</span>
          </a>
        </div>
        <div class="toc-guide">
          <a href="#appendix-glossary">
            <span class="toc-text">Glossary</span>
          </a>
        </div>
      </div>
    </nav>
    <StartHere />
    {rendered.map(({ chapter, ChapterContent, guides }) => (
      <section class="chapter" id={`ch-${chapter.data.category}`} data-chapter={chapter.data.title}>
        <header class="chapter-divider">
          <p class="chapter-numeral">{toRoman(chapter.data.number)}</p>
          <h1 class="chapter-title">{chapter.data.title}</h1>
          <div class="chapter-intro">
            <ChapterContent />
          </div>
          {CHAPTER_DIAGRAMS[chapter.data.category] && (
            <figure class="chapter-diagram" set:html={CHAPTER_DIAGRAMS[chapter.data.category]} />
          )}
        </header>
        {guides.map(({ entry, GuideContent }) => (
          <article class="guide" id={`g-${entry.data.category}-${entry.data.slug}`} data-guide={entry.data.title}>
            <h2 class="guide-title">{entry.data.title}</h2>
            <GuideContent />
          </article>
        ))}
      </section>
    ))}
    <Appendix />
  </body>
</html>
