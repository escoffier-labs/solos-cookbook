# Private hostname denylist for the publish-time scrub gate.
#
# scripts/scrub-check.mjs (the `prebuild` step) refuses to build unless this
# is set, so a deploy can never ship without hostname scrubbing. The scanner
# builds the `private-hostname` rule dynamically from this list, which is why
# no real machine names live in the committed source.
#
# Set the REAL list in your local env and in the Vercel project settings.
# It is intentionally NOT committed. Comma- and/or whitespace-separated.
SCRUB_HOSTNAMES=host1,host2,host3
